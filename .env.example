# ---- Application ----
ENVIRONMENT=development
DEBUG=true

# ---- PostgreSQL (pgvector) ----
POSTGRES_USER=aios
POSTGRES_PASSWORD=aios
POSTGRES_DB=aios
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Broker & Market-Data Gateway (openalgo) ----
GATEWAY_URL=http://gateway:5000

# ---- Azure OpenAI (LLM) ----
# Deployment name is intentionally config-driven (never hardcode the model).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
